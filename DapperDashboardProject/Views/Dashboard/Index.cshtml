@{
    Layout = null;
    ViewData["Title"] = "Gelişmiş Dashboard";
}

<!-- Timer Alert -->
@* <div class="alert mb-4" style="background: rgba(0, 210, 255, 0.1); border-left: 4px solid var(--accent-blue); color: var(--text-primary);">
    <i class="fa-solid fa-stopwatch me-2 text-info"></i> Dapper İstekleri Toplam Yanıt Süresi: <strong>@ViewBag.ExecutionTime ms</strong>
</div>
 *@
<!DOCTYPE html>

<html class="dark" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Ürün İstatistik Paneli</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8/hammer.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.2.0/dist/chartjs-plugin-zoom.min.js"></script>
    <link href="~/css/shared.css" rel="stylesheet" />
    <link href="~/css/dashboard.css" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#58a6ff",
                        "secondary": "#3fb950",
                        "error": "#f85149",
                        "warning": "#d29922",
                        "info": "#79c0ff",
                        "tertiary": "#bc8cff",
                        "surface": "#0d1117",
                        "surface-container": "#161b22",
                        "outline-variant": "#30363d",
                        "on-surface": "#dae3ee",
                        "on-surface-variant": "#8b949e"
                    },
                    borderRadius: {
                        "DEFAULT": "4px",
                        "lg": "8px",
                        "xl": "12px"
                    },
                    fontSize: {
                        "label-md": ["12px", { lineHeight: "16px", fontWeight: "500" }],
                        "body-sm": ["12px", { lineHeight: "18px" }],
                        "body-md": ["14px", { lineHeight: "20px" }],
                        "headline-sm": ["18px", { lineHeight: "24px", fontWeight: "600" }],
                        "headline-md": ["24px", { lineHeight: "32px", fontWeight: "700" }]
                    }
                }
            }
        }
    </script>
</head>
<body class="overflow-x-hidden"> 
    <!-- Side Navigation Shell -->
    <aside class="hidden lg:flex flex-col fixed left-0 top-0 h-full w-[260px] py-6 px-4 z-40 bg-surface-container border-r border-outline-variant">
        <div class="flex items-center gap-3 px-2 mb-10">
            <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center text-surface font-black text-xl">A</div>
            <div>
                <h1 class="text-headline-sm font-black text-primary leading-tight">Analitik Merkezi</h1>
                <p class="text-xs text-on-surface-variant">Ürün Paneli</p>
            </div>
        </div>
        <nav class="flex-1 space-y-1">
            <a class="flex items-center gap-3 px-4 py-3 bg-primary/10 text-primary rounded-xl font-bold transition-transform duration-200 translate-x-1" href="/Dashboard/Index">
                <span class="material-symbols-outlined">dashboard</span>
                <span class="text-label-md">Genel Bakış</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest transition-all rounded-xl" href="/Inventory/Index">
                <span class="material-symbols-outlined">inventory_2</span>
                <span class="text-label-md">Envanter Listesi</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest transition-all rounded-xl" href="/Statistics/Index">
                <span class="material-symbols-outlined">analytics</span>
                <span class="text-label-md">İleri İstatistikler</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest transition-all rounded-xl" href="/Anomalies/Index">
                <span class="material-symbols-outlined">warning</span>
                <span class="text-label-md">Anomaliler</span>
            </a>
            @* <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest transition-all rounded-xl" href="#">
                <span class="material-symbols-outlined">settings</span>
                <span class="text-label-md">Ayarlar</span>
            </a> *@
        </nav>
        <div class="mt-auto space-y-1 pt-6 border-t border-outline-variant">
            @* <button class="w-full flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container-highest rounded-xl transition-all">
                <span class="material-symbols-outlined">help</span>
                <span class="text-label-md">Yardım</span>
            </button> *@
            <button class="w-full flex items-center gap-3 px-4 py-3 text-error hover:bg-error/10 rounded-xl transition-all">
                <span class="material-symbols-outlined">logout</span>
                <span class="text-label-md">Çıkış</span>
            </button>
        </div>
    </aside>
    <!-- Main Content Wrapper -->
    <main class="lg:ml-[260px] min-h-screen pb-12">
        <!-- Top Bar -->
        <header class="sticky top-0 z-30 bg-surface/80 backdrop-blur-md border-b border-outline-variant px-6 h-16 flex items-center justify-between">
            <span id="perf-timer" class="text-[10px] font-mono text-on-surface-variant"></span>
            <div class="flex flex-col">
                <h2 class="text-headline-md font-bold text-on-surface leading-none">Ürün Analitiği</h2>
                <span class="text-xs text-on-surface-variant mt-1">Ürün Analitik Paneli</span>
            </div>
            <div class="flex items-center gap-4">
                <div class="text-right hidden sm:block">
                    <div class="text-body-sm font-mono text-on-surface-variant" id="live-timestamp">00:00:00</div>
                    <div class="text-[10px] text-secondary uppercase tracking-widest">Canlı Sistem</div>
                </div>
                <button class="p-2 hover:bg-surface-container-highest rounded-full transition-all text-primary" onclick="refreshData()" title="Refresh">
                    <span class="material-symbols-outlined">refresh</span>
                </button>
                <div class="h-8 w-8 rounded-full bg-surface-container-highest border border-outline-variant overflow-hidden">
                    <img class="w-full h-full object-cover" data-alt="A professional high-resolution corporate profile headshot of a software engineer in a dark tech-focused environment. The lighting is Moody with subtle blue rim light, emphasizing a high-performance analytics atmosphere. The background is slightly blurred showing a high-tech control room." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAGI9EJEJaTL6z18mjg0nHV_e36O_JWeHAk7WHd6VJY_fgo6sEA3bbXnGy-gBD_0YSRC3T91_y9pCFLsLCbpGcq2UdQ9xE9P3S4CyftTjjZXCSRDPPi3o6U3LOPxpV79loOpXFVe6JRBA8omDuDtWKnXO7bMDqK-8hn3ILyRl2h4LqOVy-SHwdG-fYZ9T4dF4LM4cD-BlpWVtiJryeVjMeaYQ1EFb3WLuRwpsyQ9J1QmIYo6t9paV0Kwg" />
                </div>
            </div>
        </header>
        <!-- Filter Bar -->
        <section class="sticky top-16 z-20 bg-surface-container/95 border-b border-outline-variant p-4">
            <div class="max-w-[1600px] mx-auto grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-3">
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-on-surface-variant text-sm">search</span>
                    <input class="w-full bg-surface border-outline-variant text-body-sm rounded-lg pl-9 focus:ring-primary focus:border-primary" id="search-input" placeholder="Ürün Ara..." type="text" />
                </div>
                <select class="bg-surface border-outline-variant text-body-sm rounded-lg focus:ring-primary" id="main-cat">
                    <option value="">Tüm Kategoriler</option>
                    <option value="elektronik">Elektronik</option>
                    <option value="mobilya">Mobilya</option>
                </select>
                <select class="bg-surface border-outline-variant text-body-sm rounded-lg focus:ring-primary" id="stock-status">
                    <option value="">Stok Durumu</option>
                    <option value="in-stock">Stokta</option>
                    <option value="out-of-stock">Stoksuz</option>
                    <option value="critical">Kritik</option>
                </select>
                <select class="bg-surface border-outline-variant text-body-sm rounded-lg focus:ring-primary" id="active-status">
                    <option value="">Durum (Hepsi)</option>
                    <option value="active">Aktif</option>
                    <option value="inactive">Pasif</option>
                </select>
                <div class="flex gap-2 items-center">
                    <input class="w-full bg-surface border-outline-variant text-body-sm rounded-lg" id="price-min" placeholder="Min ₺" type="number" />
                    <input class="w-full bg-surface border-outline-variant text-body-sm rounded-lg" id="price-max" placeholder="Max ₺" type="number" />
                </div>
                <button class="bg-primary text-surface font-bold text-label-md py-2 px-4 rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2" onclick="applyFilters()">
                    <span class="material-symbols-outlined text-sm">filter_alt</span> Filtrele
                </button>
                <button class="border border-outline-variant text-on-surface font-bold text-label-md py-2 px-4 rounded-lg hover:bg-surface-container-highest transition-all flex items-center justify-center gap-2" onclick="exportReport()">
                    <span class="material-symbols-outlined text-sm">download</span> Export
                </button>
            </div>
        </section>
        <div class="px-6 mt-8 space-y-8 max-w-[1600px] mx-auto">
            <!-- KPI Grid -->
            <!-- KPI Grid -->
            <div class="grid grid-cols-2 md:grid-cols-4 xl:grid-cols-8 gap-4">

                <!-- KPI 1 -->
                <div class="glass-card p-4 rounded-xl">
                    <div class="flex items-start justify-between">
                        <span class="text-[10px] uppercase font-bold text-on-surface-variant tracking-wider leading-tight">Toplam Ürün</span>
                        <span class="material-symbols-outlined text-primary text-xl flex-shrink-0">inventory_2</span>
                    </div>
                    <div class="mt-2">
                        <div class="text-2xl font-bold" id="kpi-total">0</div>
                        <div class="text-[10px] text-secondary flex items-center mt-1">
                            <span class="material-symbols-outlined text-[12px]">trending_up</span> +2.4%
                        </div>
                    </div>
                </div>

                <!-- KPI 2 -->
                <div class="glass-card p-4 rounded-xl">
                    <div class="flex items-start justify-between">
                        <span class="text-[10px] uppercase font-bold text-on-surface-variant tracking-wider leading-tight">Aktif Ürün</span>
                        <span class="material-symbols-outlined text-secondary text-xl flex-shrink-0">check_circle</span>
                    </div>
                    <div class="mt-2">
                        <div class="text-2xl font-bold" id="kpi-active">0</div>
                        <div class="text-[10px] text-on-surface-variant mt-1">Toplam içinde</div>
                    </div>
                </div>

                <!-- KPI 3 -->
                <div class="glass-card p-4 rounded-xl">
                    <div class="flex items-start justify-between">
                        <span class="text-[10px] uppercase font-bold text-on-surface-variant tracking-wider leading-tight">Pasif Ürün</span>
                        <span class="material-symbols-outlined text-on-surface-variant text-xl flex-shrink-0">pause_circle</span>
                    </div>
                    <div class="mt-2">
                        <div class="text-2xl font-bold" id="kpi-inactive">0</div>
                        <div class="text-[10px] text-error flex items-center mt-1">
                            <span class="material-symbols-outlined text-[12px]">trending_down</span> -0.5%
                        </div>
                    </div>
                </div>

                <!-- KPI 4 -->
                <div class="glass-card p-4 rounded-xl border-l-4 border-l-error">
                    <div class="flex items-start justify-between">
                        <span class="text-[10px] uppercase font-bold text-on-surface-variant tracking-wider leading-tight">Stok Yok</span>
                        <span class="material-symbols-outlined text-error text-xl flex-shrink-0">error</span>
                    </div>
                    <div class="mt-2">
                        <div class="text-2xl font-bold" id="kpi-oos">0</div>
                        <div class="text-[10px] text-error font-medium mt-1">Acil İnceleme</div>
                    </div>
                </div>

                <!-- KPI 5 -->
                <div class="glass-card p-4 rounded-xl border-l-4 border-l-warning">
                    <div class="flex items-start justify-between">
                        <span class="text-[10px] uppercase font-bold text-on-surface-variant tracking-wider leading-tight">Kritik Stok</span>
                        <span class="material-symbols-outlined text-warning text-xl flex-shrink-0">warning</span>
                    </div>
                    <div class="mt-2">
                        <div class="text-2xl font-bold" id="kpi-critical">0</div>
                        <div class="text-[10px] text-warning mt-1">Yeniden sipariş ver</div>
                    </div>
                </div>

                <!-- KPI 6 — FİYAT TAŞMA DÜZELTMESİ -->
                <div class="glass-card p-4 rounded-xl">
                    <div class="flex items-start justify-between gap-1">
                        <span class="text-[10px] uppercase font-bold text-on-surface-variant tracking-wider leading-tight">Ort. Fiyat</span>
                        <span class="material-symbols-outlined text-info text-xl flex-shrink-0">payments</span>
                    </div>
                    <div class="mt-2 min-w-0">
                        <!--
                            text-xl (20px) kullanıyoruz, text-2xl yerine.
                            truncate + title attribute ile taşma engellenir,
                            gerçek değer hover'da tooltip olarak görünür.
                        -->
                        <div class="text-xl font-bold truncate" id="kpi-avg-price" title="">₺0</div>
                        <div class="text-[10px] text-secondary mt-1">Aktif ürünler</div>
                    </div>
                </div>

                <!-- KPI 7 -->
                <div class="glass-card p-4 rounded-xl">
                    <div class="flex items-start justify-between">
                        <span class="text-[10px] uppercase font-bold text-on-surface-variant tracking-wider leading-tight">Kategoriler</span>
                        <span class="material-symbols-outlined text-tertiary text-xl flex-shrink-0">category</span>
                    </div>
                    <div class="mt-2">
                        <div class="text-2xl font-bold" id="kpi-cats">0</div>
                        <div class="text-[10px] text-on-surface-variant mt-1">Ana grup</div>
                    </div>
                </div>

                <!-- KPI 8 -->
                <div class="glass-card p-4 rounded-xl">
                    <div class="flex items-start justify-between">
                        <span class="text-[10px] uppercase font-bold text-on-surface-variant tracking-wider leading-tight">Envanter Değ.</span>
                        <span class="material-symbols-outlined text-orange-400 text-xl flex-shrink-0">account_balance_wallet</span>
                    </div>
                    <div class="mt-2 min-w-0">
                        <div class="text-xl font-bold truncate" id="kpi-inv-value" title="">₺0</div>
                        <div class="text-[10px] text-secondary mt-1">Canlı Hesaplama</div>
                    </div>
                </div>

            </div>
            <!-- Chart Bento Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                <!-- Row 1 -->
                <div class="glass-card p-6 rounded-xl expandable-card" onclick="openDetailModal('catDistribution')">
                    <h3 class="text-label-md font-bold text-on-surface-variant uppercase mb-4">Ana Kategori Dağılımı</h3>
                    <div class="chart-container" id="chart-main-cat"></div>
                    <div class="expand-hint"><span class="material-symbols-outlined" style="font-size:14px">open_in_full</span> Detay için tıklayın</div>
                </div>
                <div class="glass-card p-6 rounded-xl">
                    <h3 class="text-label-md font-bold text-on-surface-variant uppercase mb-4">Aktif / Pasif Durumu</h3>
                    <div class="chart-container" id="chart-status-donut"></div>
                </div>
                <div class="glass-card p-6 rounded-xl expandable-card" onclick="openDetailModal('catStatusSplit')">
                    <h3 class="text-label-md font-bold text-on-surface-variant uppercase mb-4">Kategori Durum Karşılaştırması</h3>
                    <div class="chart-container" id="chart-cat-split"></div>
                    <div class="expand-hint"><span class="material-symbols-outlined" style="font-size:14px">open_in_full</span> Detay için tıklayın</div>
                </div>
                <!-- Row 2 -->
                <div class="glass-card p-6 rounded-xl">
                    <h3 class="text-label-md font-bold text-on-surface-variant uppercase mb-4">Fiyat Aralığı Dağılımı</h3>
                    <div class="chart-container" id="chart-price-dist"></div>
                </div>
                <div class="glass-card p-6 rounded-xl">
                    <h3 class="text-label-md font-bold text-on-surface-variant uppercase mb-4">ABC Analizi (Gelir & Stok)</h3>
                    <div class="chart-container" id="chart-abc"></div>
                </div>
                <div class="glass-card p-6 rounded-xl">
                    <h3 class="text-label-md font-bold text-on-surface-variant uppercase mb-4">Stok Risk Matrisi</h3>
                    <div class="chart-container" id="chart-risk"></div>
                </div>
                <!-- Row 3 Special Widgets -->
                <div class="glass-card p-6 rounded-xl xl:col-span-2" id="category-health-section">
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-label-md font-bold text-on-surface-variant uppercase">Kategori Sağlık Performansı</h3>
                        <div class="flex gap-2">
                            <span class="w-3 h-3 rounded-full bg-secondary"></span> <span class="text-[10px]">Optimal</span>
                            <span class="w-3 h-3 rounded-full bg-warning"></span> <span class="text-[10px]">Uyarı</span>
                        </div>
                    </div>
                    <div class="accordion-fade collapsed">
                        <div class="accordion-wrapper collapsed" id="health-accordion-wrapper">
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-6" id="category-health-bars">
                                <!-- Progress bars injected by JS -->
                            </div>
                        </div>
                    </div>
                    <button class="accordion-toggle-btn" id="health-toggle-btn" onclick="toggleCategoryHealth()">
                        <span class="material-symbols-outlined">expand_more</span> Daha Fazla Göster
                    </button>
                </div>
                <div class="glass-card p-6 rounded-xl expandable-card" onclick="openDetailModal('radar')">
                    <h3 class="text-label-md font-bold text-on-surface-variant uppercase mb-4">Kategori Karşılaştırma Endeksi</h3>
                    <div class="chart-container" id="chart-radar"></div>
                    <div class="expand-hint"><span class="material-symbols-outlined" style="font-size:14px">open_in_full</span> Detay için tıklayın</div>
                </div>
            </div>
            <!-- Widgets Row -->
            <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
                <!-- Top 10 Inventory -->
                <div class="lg:col-span-1 glass-card rounded-xl flex flex-col">
                    <div class="p-4 border-b border-outline-variant flex justify-between items-center">
                        <h4 class="text-label-md font-bold">En Yüksek 10 Envanter Değeri</h4>
                        <span class="material-symbols-outlined text-sm">leaderboard</span>
                    </div>
                    <div class="p-4 flex-1 space-y-4" id="top-inventory-list">
                        <!-- List via JS -->
                    </div>
                </div>
                <!-- Price Anomalies -->
                <div class="lg:col-span-1 glass-card rounded-xl flex flex-col">
                    <div class="p-4 border-b border-outline-variant bg-error/5">
                        <h4 class="text-label-md font-bold text-error flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">error</span> Fiyat Anomalileri
                        </h4>
                    </div>
                    <div class="p-4 space-y-3" id="anomalies-list">
                        <!-- Anomalies via JS -->
                    </div>
                </div>
                <!-- Price Percentile / Stats -->
                <div class="lg:col-span-2 glass-card rounded-xl expandable-card" onclick="openDetailModal('priceStats')">
                    <div class="p-4 border-b border-outline-variant flex items-center justify-between">
                        <h4 class="text-label-md font-bold">Fiyat İstatistikleri & Dağılımı</h4>
                        <div class="expand-hint" style="margin-top:0"><span class="material-symbols-outlined" style="font-size:14px">open_in_full</span> Detay</div>
                    </div>
                    <div class="p-6">
                        <div class="h-32 mb-8" id="chart-percentile"></div>
                        <div class="grid grid-cols-3 gap-4 border-t border-outline-variant pt-6">
                            <div class="text-center">
                                <div class="text-[10px] text-on-surface-variant uppercase">Medyan Fiyat</div>
                                <div class="text-xl font-bold text-primary">₺1.450</div>
                            </div>
                            <div class="text-center">
                                <div class="text-[10px] text-on-surface-variant uppercase">En Yüksek</div>
                                <div class="text-xl font-bold text-secondary">₺12.900</div>
                            </div>
                            <div class="text-center">
                                <div class="text-[10px] text-on-surface-variant uppercase">Değişkenlik</div>
                                <div class="text-xl font-bold text-warning">8.4%</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Product Table Section -->
            <div class="glass-card rounded-xl overflow-hidden">
                <div class="border-b border-outline-variant flex flex-col md:flex-row md:items-center justify-between p-4 gap-4">
                    <div class="flex border-b border-transparent">
                        <button class="px-4 py-2 text-label-md font-bold border-b-2 border-primary text-primary transition-all">📦 Tüm Ürünler</button>
                        <button class="px-4 py-2 text-label-md font-bold text-on-surface-variant hover:text-on-surface transition-all">⚠️ Kritik Stok</button>
                        <button class="px-4 py-2 text-label-md font-bold text-on-surface-variant hover:text-on-surface transition-all">🚨 Stoksuz</button>
                    </div>
                    <div class="flex gap-2">
                        <div class="relative">
                            <input class="bg-surface border-outline-variant text-body-sm rounded-lg pl-4 pr-10 h-9 w-64 focus:ring-primary" placeholder="Tabloda ara..." type="text" />
                            <span class="absolute right-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-on-surface-variant text-sm">search</span>
                        </div>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-surface-container-low border-b border-outline-variant">
                                <th class="p-4 text-label-md text-on-surface-variant font-bold uppercase tracking-wider">ID</th>
                                <th class="p-4 text-label-md text-on-surface-variant font-bold uppercase tracking-wider">Ürün Bilgisi</th>
                                <th class="p-4 text-label-md text-on-surface-variant font-bold uppercase tracking-wider">Kategori</th>
                                <th class="p-4 text-label-md text-on-surface-variant font-bold uppercase tracking-wider">Fiyat</th>
                                <th class="p-4 text-label-md text-on-surface-variant font-bold uppercase tracking-wider">Stok</th>
                                <th class="p-4 text-label-md text-on-surface-variant font-bold uppercase tracking-wider">Durum</th>
                                <th class="p-4 text-label-md text-on-surface-variant font-bold uppercase tracking-wider text-right">İşlem</th>
                            </tr>
                        </thead>
                        <tbody id="product-tbody">
                            <!-- Rows injected by JS -->
                        </tbody>
                    </table>
                </div>
                <div class="p-4 border-t border-outline-variant flex items-center justify-between bg-surface-container-low" id="pagination-footer">
                    <span class="text-body-sm text-on-surface-variant">Yükleniyor...</span>
                    <div class="flex gap-2"></div>
                </div>
            </div>
        </div>
    </main>
    <!-- Side Drawer (Detail Panel) -->
    <div class="fixed inset-0 z-50 pointer-events-none overflow-hidden" id="side-drawer">
        <div class="absolute inset-0 bg-black/60 opacity-0 transition-opacity duration-300 pointer-events-none" id="drawer-backdrop"></div>
        <div class="absolute right-0 top-0 h-full w-full max-w-lg bg-surface border-l border-outline-variant translate-x-full transition-transform duration-300 ease-in-out pointer-events-auto drawer-shadow" id="drawer-panel">
            <div class="p-6 h-full flex flex-col">
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-headline-md font-bold text-on-surface">Ürün Detayı</h2>
                    <button class="p-2 hover:bg-surface-container-highest rounded-full" onclick="closeSideDrawer()">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                <div class="flex-1 overflow-y-auto space-y-8 pr-2">
                    <div class="aspect-video bg-surface-container rounded-xl overflow-hidden border border-outline-variant">
                        <img class="w-full h-full object-cover" data-alt="A professional product studio photography shot of a sleek high-tech electronic gadget. Soft diffuse lighting from top-left, clean dark background matching the GitHub dark theme. Deep contrast with metallic highlights and sharp details." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBJErQF3vGcMVMbsvB5ubW4uDTdOY6NXOOL1hnAvPI_n6pInDi2YUATG2zKc8Ug_oPMT4RLr2Z8w_qJtmqxWLGwCJuH0jwpADZd16Rr0cbOoA0FDGxpwB_em91Oi1C_QVQ7pt6sDZkphARwAMjsde791HNHAabtfzqSCQSYk53mU8sFgYhzBwBM46AI0a5q7uhbXnecEgxwj_6Pdvjkyjwi2kQ2n9YgYj8AYhPcjKefPc6AZXxvuP4wdg" />
                    </div>
                    <div class="space-y-4">
                        <div>
                            <span class="text-[10px] text-primary font-bold uppercase tracking-widest">Product Title</span>
                            <h3 class="text-headline-sm font-bold text-on-surface" id="drawer-title">Precision Tech Wireless Mouse</h3>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="p-4 bg-surface-container rounded-xl border border-outline-variant">
                                <span class="text-[10px] text-on-surface-variant uppercase block">Güncel Fiyat</span>
                                <span class="text-xl font-bold text-secondary" id="drawer-price">₺1.240,00</span>
                            </div>
                            <div class="p-4 bg-surface-container rounded-xl border border-outline-variant">
                                <span class="text-[10px] text-on-surface-variant uppercase block">Stok Seviyesi</span>
                                <span class="text-xl font-bold text-warning" id="drawer-stock">42 Units</span>
                            </div>
                        </div>
                        <div class="p-4 bg-surface-container rounded-xl border border-outline-variant">
                            <span class="text-[10px] text-on-surface-variant uppercase block mb-2">Envanter Değeri</span>
                            <div class="flex items-end gap-2">
                                <span class="text-2xl font-black text-on-surface" id="drawer-value">₺52.080,00</span>
                                <span class="text-xs text-secondary font-bold mb-1">(+12% vs LY)</span>
                            </div>
                        </div>
                    </div>
                    <div>
                        <span class="text-[10px] text-on-surface-variant font-bold uppercase block mb-2">Description</span>
                        <p class="text-body-md text-on-surface-variant leading-relaxed">
                            Ergonomik tasarım ve ultra hassas sensör teknolojisi ile donatılmış, uzun süreli kullanım için optimize edilmiş yeni nesil kablosuz fare. Enerji verimliliği yüksek çip seti sayesinde tek şarjla 60 güne kadar kullanım sunar.
                        </p>
                    </div>
                    <div class="space-y-4 pt-4">
                        <h4 class="text-label-md font-bold uppercase border-b border-outline-variant pb-2">Teknik Özellikler</h4>
                        <div class="grid grid-cols-2 gap-y-3 text-body-sm">
                            <div class="text-on-surface-variant">Model:</div> <div class="text-on-surface">PT-XM2024</div>
                            <div class="text-on-surface-variant">SKU:</div> <div class="text-on-surface">SKU-9902-X</div>
                            <div class="text-on-surface-variant">Last Update:</div> <div class="text-on-surface">12.05.2024</div>
                            <div class="text-on-surface-variant">Location:</div> <div class="text-on-surface">Warehouse B-4</div>
                        </div>
                    </div>
                </div>
                <div class="pt-6 border-t border-outline-variant grid grid-cols-2 gap-4">
                    <button class="py-3 bg-primary text-surface font-bold rounded-xl hover:opacity-90 transition-all">Düzenle</button>
                    <button class="py-3 border border-outline-variant text-on-surface font-bold rounded-xl hover:bg-surface-container-highest transition-all">Rapor Al</button>
                </div>
            </div>
        </div>
    </div>
    <!-- Görev 2: Detail Modal -->
    <div class="detail-modal-overlay" id="detail-modal-overlay" onclick="if(event.target===this) closeDetailModal()">
        <div class="detail-modal-panel">
            <div class="detail-modal-header">
                <h3 id="detail-modal-title"><span class="material-symbols-outlined text-primary">analytics</span> Detay Görünüm</h3>
                <button class="detail-modal-close" onclick="closeDetailModal()">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="detail-modal-body" id="detail-modal-body">
                <!-- Chart rendered dynamically -->
            </div>
        </div>
    </div>
    <!-- Initialization & Interactivity Script -->
    <script src="~/js/shared.js"></script>
    <script src="~/js/dashboard.js"></script>
</body>
</html>