@using DapperDashboardProject.Dtos.ProductDtos
@model List<ResultProductDto>
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>IndexAsync</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

</head>
<body>
    <div class="container mt-5">
        <h2>Kategori Listesi</h2>
        <a href="/Categories/CreateCategoryAsync" class="btn btn-primary mb-3">Yeni Kategori</a>

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Ürün Adı</th>
                    <th>Kategori</th>
                    <th>Fiyat</th>
                    <th>Stok</th>
                    <th>Durum</th>
                    <th>Sil</th>
                    <th>Güncelle</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#</td>
                        <td>@item.ProductName</td>
                        <td>@item.CategoryName</td>
                        <td>@item.Price</td>
                        <td>@item.Stock</td>
                        <td>@(item.IsActive ? "Aktif" : "Pasif")</td>
                        <td>
                            <a href="#" class="btn btn-danger btn-sm">Sil</a>
                        </td>
                        <td>
                            <a href="/Categories/UpdateCategoryAsync/" class="btn btn-success btn-sm">Güncelle</a>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>

</body>
</html>