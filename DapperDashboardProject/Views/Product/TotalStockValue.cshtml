
@{
    Layout = null;
    ViewData["Title"] = "Toplam Stok Değeri";
}

<!DOCTYPE html>
<html>
<head>
    <title>Toplam Stok Değeri</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            font-family: 'Segoe UI', sans-serif;
        }

        .stock-card {
            width: 450px;
            padding: 35px;
            border-radius: 25px;
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255,255,255,0.15);
            box-shadow: 0 15px 35px rgba(0,0,0,.3);
            text-align: center;
            color: white;
            transition: .3s;
        }

        .stock-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 45px rgba(0,0,0,.4);
        }

        .icon {
            font-size: 60px;
            margin-bottom: 15px;
        }

        .title {
            font-size: 20px;
            color: #cbd5e1;
            margin-bottom: 20px;
            letter-spacing: 1px;
        }

        .value {
            font-size: 48px;
            font-weight: 700;
            color: #22c55e;
            margin-bottom: 15px;
        }

        .description {
            color: #94a3b8;
            font-size: 15px;
        }

        .line {
            width: 80px;
            height: 4px;
            background: #22c55e;
            margin: 20px auto;
            border-radius: 20px;
        }
    </style>
</head>
<body>

    <div class="stock-card">

        <div class="icon">
            📦
        </div>

        <div class="title">
            TOPLAM STOK DEĞERİ
        </div>

        <div class="line"></div>

        <div class="value">
            @Convert.ToDecimal(ViewBag.TotalStockValue).ToString("N2") ₺
        </div>

        <div class="description">
            Sistemde kayıtlı tüm ürünlerin güncel stok değeri
        </div>

    </div>

</body>
</html>